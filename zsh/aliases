# Arch Based Aliases
alias update='sudo pacman -Syu --noconfirm && yay -Syu'
alias clean='sudo pacman -Rns $(pacman -Qtdq) && sudo pacman -Scc && yay -Yc'
alias sps='sudo pacman -S --needed --noconfirm'
alias spss='sudo pacman -Ss'
alias spr='sudo pacman -Rns --noconfirm'

# General Terminal Aliases
alias l='ls -lathir --color=auto --group-directories-first'
alias grep='grep --color=auto'
alias shred='shred -vfzu'

# i3 Based Aliases
alias i3config="nvim $DOTFILES/i3/config"
alias i3status="nvim $DOTFILES/i3/i3status.conf"

# ZSH Aliases
alias aliases="nvim $ZDOTDIR/aliases"

# Keyboard Aliases
alias cm='setxkbmap gb -variant colemak'
alias pt='setxkbmap pt'
